\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Comparison of wavefront tiling strategies for parallel seam carving. Case 1 (top) shows a non-uniform distribution of synchronization points (pink dots) due to a two-block tip. Case 2 (bottom) uses a single-block tip and uniform distribution of pink dots.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:tiling_strategies}{{1}{2}{Comparison of wavefront tiling strategies for parallel seam carving. Case 1 (top) shows a non-uniform distribution of synchronization points (pink dots) due to a two-block tip. Case 2 (bottom) uses a single-block tip and uniform distribution of pink dots}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Bidirectional seam carving synchronization at the image midpoint $\bar  {y}$. The upward and downward wavefronts (red arrows) converge at the central row, where the optimal transition point $\hat  {x}$ is determined by minimizing the combined energy from both computed halves.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:midpoint_sync}{{2}{3}{Bidirectional seam carving synchronization at the image midpoint $\bar {y}$. The upward and downward wavefronts (red arrows) converge at the central row, where the optimal transition point $\hat {x}$ is determined by minimizing the combined energy from both computed halves}{figure.2}{}}
